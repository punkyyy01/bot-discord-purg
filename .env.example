# Copia este archivo a .env y pon tus credenciales
# NO coloques tokens reales aquí; usa .env (este archivo es público)

# Token del bot de Discord (obligatorio)
DISCORD_TOKEN=tu-token-de-bot-aqui

# Habilitar lectura de contenido de mensajes (requiere habilitarlo en el Developer Portal)
ENABLE_MESSAGE_CONTENT=true

# API Key de Google Gemini (obligatorio para chat LLM)
GOOGLE_API_KEY=tu-google-api-key

# Modelo de Gemini (opcional, por defecto: gemini-1.5-flash-latest)
GEMINI_MODEL=gemini-2.0-flash

# Modelos de respaldo separados por coma (opcional)
# GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-2.0-flash

# Timeout en segundos para llamadas al LLM (opcional, por defecto: 45)
GEMINI_TIMEOUT=45

# ID del servidor para sync instantáneo de slash commands (opcional)
# Sin esto, los comandos tardan hasta 1 hora en propagarse
GUILD_ID=tu-id-de-servidor
